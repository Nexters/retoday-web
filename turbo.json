{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": ["MODE", "NODE_ENV"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": [],
      "env": ["MODE", "NODE_ENV"]
    },
    "check-types": {
      "dependsOn": ["^check-types"],
      "env": ["MODE", "NODE_ENV"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["MODE", "NODE_ENV"]
    }
  }
}
